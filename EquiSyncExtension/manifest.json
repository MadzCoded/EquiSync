{
  "manifest_version": 3,
  "name": "EquiSync – Horse Reality Helper",
  "version": "0.3.2",
  "description": "EquiSync helper for Horse Reality.",
  "permissions": ["storage"],
  "content_scripts": [
    {
"matches": [
  "*://horsereality.com/horses/*",
  "*://www.horsereality.com/horses/*",
  "*://v2.horsereality.com/horses/*",
  "https://madzcoded.github.io/EquiSync/*"
]
      "js": ["content.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://madzcoded.github.io/EquiSync/*"],
      "exclude_matches": ["https://madzcoded.github.io/EquiSync/assets/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
