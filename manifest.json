{
  "manifest_version": 3,
  "name": "EquiSync - Horse Reality Helper",
  "version": "0.1.0",
  "description": "Adds a button on Horse Reality horse pages to send the horse's name to the EquiSync planner.",
  "permissions": [],
  "host_permissions": [
    "*://horsereality.com/*",
    "*://www.horsereality.com/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "*://horsereality.com/*",
        "*://www.horsereality.com/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
